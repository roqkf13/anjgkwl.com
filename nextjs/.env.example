DATABASE_URL=
GEMINI_API_KEY=

# 백엔드(FastAPI) 기본 주소. Naver 콜백에서 /auth/oauth/upsert 호출에 사용됨.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Naver OAuth: https://developers.naver.com/apps
NAVER_CLIENT_ID=네이버에서_발급받은_Client_ID
NAVER_CLIENT_SECRET=네이버에서_발급받은_Client_Secret
NAVER_REDIRECT_URI=https://anjgkwl.com/api/auth/callback/naver

# FastAPI의 INTERNAL_OAUTH_SECRET과 동일한 값이어야 함.
# /auth/oauth/upsert 호출이 신뢰된 서버(Next.js)에서 왔는지 검증하는 공유 비밀값.
INTERNAL_OAUTH_SECRET=
