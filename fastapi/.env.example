GOOGLE_CLIENT_ID=구글에서_발급받은_Client_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=구글에서_발급받은_Client_Secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google


FRONTEND_BASE_URL=http://127.0.0.1:3000

NAVER_CLIENT_ID=네이버에서_발급받은_Client_ID
NAVER_CLIENT_SECRET=네이버에서_발급받은_Client_Secret
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

KAKAO_CLIENT_ID=카카오_REST_API_키
